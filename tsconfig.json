{
	// "$schema": "https://json.schemastore.org/tsconfig.json",+
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"types": ["jest", "node"]
	},
	"include": ["src/**/*", "tests/**/*"],
	"exclude": ["node_modules"]
}
